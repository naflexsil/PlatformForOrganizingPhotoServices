# Сервер
PORT=3000

# PostgreSQL (должны совпадать с docker-compose.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=photoservices_db

# Строка подключения для Prisma CLI (migrate, studio и др.)
# Значение собирается из переменных выше: postgresql://{USER}:{PASSWORD}@{HOST}:{PORT}/{NAME}
DATABASE_URL=postgresql://postgres:password@localhost:5433/photoservices_db

# JWT — для дев-окружения можно оставить эти значения
JWT_SECRET=s3cr3t_k3y_f0r_ph0t0s3rv1c3s_d3v
JWT_REFRESH_SECRET=r3fr3sh_s3cr3t_ph0t0s3rv1c3s_d3v

# VK ID приложение — получить на https://id.vk.com/business/go
# (нужно только для реального входа через VK; mock-login работает без этих значений)
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret
VK_SERVICE_TOKEN=your_vk_service_token
VK_REDIRECT_URI=http://localhost:3000/api/auth/callback
