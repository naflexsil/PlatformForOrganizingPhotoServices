# Сервер
PORT=3000
BACKEND_URL=http://localhost:3000   # публичный URL бэкенда (используется для генерации ссылок на файлы)
FRONTEND_URL=http://localhost:3001  # на проде: https://psyshe.art

# PostgreSQL (должны совпадать с docker-compose.yml)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=photoservices_db

# Строка подключения для Prisma CLI (migrate, studio и др.)
# Значение собирается из переменных выше: postgresql://{USER}:{PASSWORD}@{HOST}:{PORT}/{NAME}
DATABASE_URL=postgresql://postgres:password@localhost:5433/photoservices_db

# JWT — для дев-окружения можно оставить эти значения
JWT_SECRET=s3cr3t_k3y_f0r_ph0t0s3rv1c3s_d3v
JWT_REFRESH_SECRET=r3fr3sh_s3cr3t_ph0t0s3rv1c3s_d3v

# Garage S3 
S3_ENDPOINT=http://localhost:3900        # адрес Garage 
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_ORIGINALS=originals            # бакет для оригиналов
S3_BUCKET_PREVIEWS=previews              # бакет для WebP-превью
S3_BUCKET_AVATARS=avatars                # бакет для аватаров
S3_BUCKET_SEARCH=search                  # бакет для фото поиска

# VK ID приложение — получить на https://id.vk.com/business/go
# (нужно только для реального входа через VK; mock-login работает без этих значений)
VK_APP_ID=your_vk_app_id
VK_APP_SECRET=your_vk_app_secret
VK_SERVICE_TOKEN=your_vk_service_token
VK_REDIRECT_URI=http://localhost:3000/api/auth/callback  # на проде: https://psyshe.art/api/auth/callback
